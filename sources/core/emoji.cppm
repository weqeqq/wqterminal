      {"zambia", "\xf0\x9f\x87\xbf\xf0\x9f\x87\xb2"},
      {"zany_face", "\xf0\x9f\xa4\xaa"},
      {"zap", "\xe2\x9a\xa1"},
      {"zebra", "\xf0\x9f\xa6\x93"},
      {"zero", "\x30\xef\xb8\x8f\xe2\x83\xa3"},
      {"zimbabwe", "\xf0\x9f\x87\xbf\xf0\x9f\x87\xbc"},
      {"zipper-mouth_face", "\xf0\x9f\xa4\x90"},
      {"zipper__mouth_face", "\xf0\x9f\xa4\x90"},
      {"zombie", "\xf0\x9f\xa7\x9f"},
      {"zzz", "\xf0\x9f\x92\xa4"},
      {"åland_islands", "\xf0\x9f\x87\xa6\xf0\x9f\x87\xbd"},
  };
  return codes;
}

}

export namespace weqeqq::terminal {

inline std::string ReplaceEmoji(std::string_view text) {
  std::string out;
  out.reserve(text.size());
  std::size_t i = 0;
  const auto& codes = detail::EmojiCodes();
  while (i < text.size()) {
    if (text[i] == ':') {
      std::size_t close = text.find(':', i + 1);
      if (close != std::string_view::npos && close > i + 1) {
        std::string_view name = text.substr(i + 1, close - i - 1);
        bool valid = true;
        for (char c : name) {
          if (!((c >= 'a' && c <= 'z') || (c >= '0' && c <= '9') || c == '_' ||
                c == '-' || c == '+')) {
            valid = false;
            break;
          }
        }
        if (valid) {
          auto it = codes.find(std::string(name));
          if (it != codes.end()) {
            out += it->second;
            i = close + 1;
            continue;
          }
        }
      }
    }
    out.push_back(text[i]);
    ++i;
  }
  return out;
}

}
