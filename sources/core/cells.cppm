constexpr int CodepointCellSize(std::uint32_t cp) {
  std::size_t lo = 0;
  std::size_t hi = kCellWidths.size();
  while (lo < hi) {
    std::size_t mid = lo + (hi - lo) / 2;
    const CellRange& r = kCellWidths[mid];
    if (cp < r.start) {
      hi = mid;
    } else if (cp > r.end) {
      lo = mid + 1;
    } else {
      return r.width;
    }
  }
  return 1;
}

inline std::uint32_t DecodeUtf8(std::string_view s, std::size_t& i) {
  unsigned char c = static_cast<unsigned char>(s[i]);
  if (c < 0x80) {
    ++i;
    return c;
  }
  int extra;
  std::uint32_t cp;
  if ((c & 0xe0) == 0xc0) {
    extra = 1;
    cp = c & 0x1f;
  } else if ((c & 0xf0) == 0xe0) {
    extra = 2;
    cp = c & 0x0f;
  } else if ((c & 0xf8) == 0xf0) {
    extra = 3;
    cp = c & 0x07;
  } else {
    ++i;
    return c;
  }
  if (i + extra >= s.size()) {
    ++i;
    return c;
  }
  for (int k = 1; k <= extra; ++k) {
    unsigned char cc = static_cast<unsigned char>(s[i + k]);
    if ((cc & 0xc0) != 0x80) {
      ++i;
      return c;
    }
    cp = (cp << 6) | (cc & 0x3f);
  }
  i += extra + 1;
  return cp;
}

inline void EncodeUtf8(std::uint32_t cp, std::string& out) {
  if (cp < 0x80) {
    out.push_back(static_cast<char>(cp));
  } else if (cp < 0x800) {
    out.push_back(static_cast<char>(0xc0 | (cp >> 6)));
    out.push_back(static_cast<char>(0x80 | (cp & 0x3f)));
  } else if (cp < 0x10000) {
    out.push_back(static_cast<char>(0xe0 | (cp >> 12)));
    out.push_back(static_cast<char>(0x80 | ((cp >> 6) & 0x3f)));
    out.push_back(static_cast<char>(0x80 | (cp & 0x3f)));
  } else {
    out.push_back(static_cast<char>(0xf0 | (cp >> 18)));
    out.push_back(static_cast<char>(0x80 | ((cp >> 12) & 0x3f)));
    out.push_back(static_cast<char>(0x80 | ((cp >> 6) & 0x3f)));
    out.push_back(static_cast<char>(0x80 | (cp & 0x3f)));
  }
}

}

export namespace weqeqq::terminal {

inline int GetCodepointCellSize(char32_t codepoint) {
  return detail::CodepointCellSize(static_cast<std::uint32_t>(codepoint));
}

inline int CellLen(std::string_view text) {
  int total = 0;
  for (std::size_t i = 0; i < text.size();) {
    total += detail::CodepointCellSize(detail::DecodeUtf8(text, i));
  }
  return total;
}

inline int CellLen(std::u32string_view text) {
  int total = 0;
  for (char32_t cp : text) {
    total += detail::CodepointCellSize(static_cast<std::uint32_t>(cp));
  }
  return total;
}

inline std::u32string ToCodepoints(std::string_view s) {
  std::u32string out;
  for (std::size_t i = 0; i < s.size();) {
    out.push_back(static_cast<char32_t>(detail::DecodeUtf8(s, i)));
  }
  return out;
}

inline std::string FromCodepoints(std::u32string_view s) {
  std::string out;
  for (char32_t cp : s) detail::EncodeUtf8(static_cast<std::uint32_t>(cp), out);
  return out;
}

inline std::string SetCellSize(std::string_view text, int total) {
  if (total <= 0) {
    return std::string();
  }
  int size = 0;
  std::size_t i = 0;
  std::size_t last_full = 0;
  int last_full_size = 0;
  while (i < text.size()) {
    std::size_t start = i;
    std::uint32_t cp = detail::DecodeUtf8(text, i);
    int w = detail::CodepointCellSize(cp);
    if (size + w > total) {
      std::string out(text.substr(0, last_full));
      while (last_full_size < total) {
        out.push_back(' ');
        ++last_full_size;
      }
      (void)start;
      return out;
    }
    size += w;
    last_full = i;
    last_full_size = size;
    if (size == total) {
      return std::string(text.substr(0, i));
    }
  }
  std::string out(text);
  while (size < total) {
    out.push_back(' ');
    ++size;
  }
  return out;
}

}
